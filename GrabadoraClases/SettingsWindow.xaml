<Window x:Class="GrabadoraClases.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración" Height="520" Width="520"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="24">

        <TextBlock DockPanel.Dock="Top" Text="⚙  Configuración" FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,20"/>

        <!-- Buttons at bottom -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancelar" Style="{StaticResource SecondaryButton}"
                    Click="CancelButton_Click" Margin="0,0,8,0" Width="90"/>
            <Button Content="Guardar" Style="{StaticResource ModernButton}"
                    Click="SaveButton_Click" Width="90"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- API Key -->
                <TextBlock Text="API Key de Anthropic" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="ApiKeyBox" Grid.Column="0"
                                 Background="{StaticResource Surface2Brush}"
                                 Foreground="{StaticResource TextBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 BorderThickness="1" Padding="8,6" FontSize="13"
                                 PasswordChanged="ApiKeyBox_PasswordChanged"/>
                    <Button Grid.Column="2" Content="👁" Style="{StaticResource SecondaryButton}"
                            Padding="10,6" Click="ToggleApiKeyVisibility_Click" x:Name="ToggleBtn"/>
                </Grid>

                <!-- Model -->
                <TextBlock Text="Modelo Whisper" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,6"/>
                <ComboBox x:Name="ModelCombo" Margin="0,0,0,4"
                          Background="{StaticResource Surface2Brush}"
                          Foreground="{StaticResource TextBrush}"
                          BorderBrush="{StaticResource BorderBrush}"
                          FontSize="13" Padding="8,6">
                    <ComboBoxItem Tag="tiny">tiny   — tiempo real, rápido (~75MB) ★ recomendado</ComboBoxItem>
                    <ComboBoxItem Tag="base">base   — equilibrado, buena precisión (~150MB)</ComboBoxItem>
                    <ComboBoxItem Tag="small">small  — alta precisión, lento para tiempo real (~170MB)</ComboBoxItem>
                    <ComboBoxItem Tag="medium">medium — máxima precisión, muy lento (~500MB)</ComboBoxItem>
                </ComboBox>
                <TextBlock x:Name="ModelsPathLabel" FontSize="11"
                           Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,8"
                           TextWrapping="Wrap"/>

                <!-- Recording language -->
                <TextBlock Text="Idioma de grabación" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,6"/>
                <ComboBox x:Name="LangCombo" Margin="0,0,0,4"
                          Background="{StaticResource Surface2Brush}"
                          Foreground="{StaticResource TextBrush}"
                          BorderBrush="{StaticResource BorderBrush}"
                          FontSize="13" Padding="8,6">
                    <ComboBoxItem Tag="es">Español</ComboBoxItem>
                    <ComboBoxItem Tag="en">Inglés</ComboBoxItem>
                    <ComboBoxItem Tag="fr">Francés</ComboBoxItem>
                    <ComboBoxItem Tag="de">Alemán</ComboBoxItem>
                    <ComboBoxItem Tag="it">Italiano</ComboBoxItem>
                    <ComboBoxItem Tag="pt">Portugués</ComboBoxItem>
                    <ComboBoxItem Tag="auto">Auto-detectar (menos preciso en tiempo real)</ComboBoxItem>
                </ComboBox>
                <TextBlock Text="Fijar el idioma evita detecciones erróneas en fragmentos cortos."
                           FontSize="11" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,16"/>

                <!-- Output dir -->
                <TextBlock Text="Carpeta de salida" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="OutputDirBox" Grid.Column="0" Style="{StaticResource DarkTextBox}" FontFamily="Segoe UI"/>
                    <Button Grid.Column="2" Content="📂" Style="{StaticResource SecondaryButton}"
                            Padding="10,6" Click="BrowseOutputDir_Click"/>
                </Grid>

                <!-- Initial prompt -->
                <TextBlock Text="Prompt inicial para Whisper" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,6"/>
                <TextBox x:Name="PromptBox" Style="{StaticResource DarkTextBox}"
                         AcceptsReturn="True" Height="60" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" Margin="0,0,0,4"/>
                <TextBlock Text="Ayuda a Whisper a entender el contexto (ej: terminología de la asignatura)."
                           FontSize="11" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,16"/>

                <!-- Gain -->
                <TextBlock FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,6">
                    <Run Text="Ganancia de audio: "/>
                    <Run x:Name="GainLabel" Text="12 dB"/>
                </TextBlock>
                <Slider x:Name="GainSlider" Minimum="0" Maximum="30" TickFrequency="1"
                        IsSnapToTickEnabled="True" Margin="0,0,0,4"
                        Foreground="{StaticResource AccentBrush}"
                        ValueChanged="GainSlider_ValueChanged"/>
                <TextBlock Text="Aumenta el volumen para micrófonos lejanos (12 dB recomendado)."
                           FontSize="11" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,16"/>

                <!-- Auto translate -->
                <CheckBox x:Name="AutoTranslateCheck" FontSize="13"
                          Foreground="{StaticResource TextBrush}"
                          Content="Traducir automáticamente al español (si no es español)"
                          Margin="0,0,0,8"/>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
